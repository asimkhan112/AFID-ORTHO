# Database Configuration (PostgreSQL)
# Requires a running PostgreSQL server and the psycopg2 driver (see requirements.txt).
# Format: postgresql+psycopg2://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql+psycopg2://afid_user:afid_pass@localhost:5432/afid_hms_db

# JWT Configuration
SECRET_KEY=your-secret-key-change-in-production-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Server Configuration
DEBUG=False
LOG_LEVEL=INFO

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000
